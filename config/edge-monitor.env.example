# Local settings for Tiny Edge / tiny01.stoffy.lan.
# Copy to /etc/edge-monitor.env, edit locally, and chmod 600.
# Never commit real keys, tokens, or passwords.

HOSTNAME=tiny01.stoffy.lan
TIMEZONE=Africa/Johannesburg

# LANs allowed to reach SSH, DNS, AdGuard UI, and Beszel.
LAN_CIDRS="10.0.0.0/24,192.168.101.0/24"

SSH_USER=keiki
SSH_AUTHORIZED_KEYS=""
DISABLE_PASSWORD_SSH_IF_KEY_PRESENT=true
SET_SSH_PASSWORD=true

# Lockdown remains opt-in until a second SSH session proves access.
ENABLE_FIREWALL=false

# Tiny Edge is the adguardhome-sync controller. pve02 CT201 remains
# the configuration source of truth; Tiny Edge pushes that config to replicas.
INSTALL_ADGUARD_SYNC=true
ADGUARDHOME_VERSION=v0.107.78
ADGUARDHOME_SYNC_VERSION=v0.9.2

# Lightweight edge containers.
INSTALL_BESZEL_AGENT=false
BESZEL_AGENT_IMAGE=henrygd/beszel-agent
BESZEL_LISTEN=45876
BESZEL_KEY=""
BESZEL_HUB_URL=""
BESZEL_TOKEN=""

INSTALL_CLOUDFLARED=false
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.7.2
# This file must contain one line: TUNNEL_TOKEN=<remote-managed tunnel token>
CLOUDFLARED_TOKEN_FILE=/etc/cloudflared/token.env

ADGUARD_UI_PORT=3000

# Weekly maintenance is conservative: package/tmp/rotated-log cleanup plus
# dangling Docker images. Volumes and containers are never pruned.
ENABLE_SCHEDULED_CLEANUP=true
CLEANUP_MIN_DISK_PERCENT=70
CLEANUP_DOCKER_IMAGES=true
CLEANUP_DOCKER_BUILD_CACHE=false
