# Local settings for HP t520 edge-monitor-01.
# Copy to /etc/edge-monitor.env and edit on the device.
# Do not commit real secrets.

HOSTNAME=edge-monitor-01
TIMEZONE=Africa/Johannesburg

# Comma-separated LAN CIDRs allowed to reach SSH, DNS, AdGuard UI, and Kuma.
# Add more if needed, e.g. LAN_CIDRS="10.0.0.0/24,192.168.101.0/24"
LAN_CIDRS="10.0.0.0/24"

# SSH hardening.
SSH_USER=keiki
# Paste a real public key here before running bootstrap if you want password SSH disabled safely.
# Example: SSH_AUTHORIZED_KEYS="ssh-ed25519 AAAA... keiki@pc"
SSH_AUTHORIZED_KEYS=""
DISABLE_PASSWORD_SSH_IF_KEY_PRESENT=true
# Prompt for a password on console when no SSH key is provided.
SET_SSH_PASSWORD=true

# Firewall is opt-in to avoid SSH lockout during first install.
# After SSH works, run: ENABLE_FIREWALL=true sh /root/stoffberg-edge-monitor/scripts/setup-firewall-nftables.sh
ENABLE_FIREWALL=false

# The HP edge box is normally a sync target, not the sync controller.
# Leave this false if pve02 runs adguardhome-sync and pushes config here.
INSTALL_ADGUARD_SYNC=false

# Pinned versions used by installers.
ADGUARDHOME_VERSION=v0.107.78
ADGUARDHOME_SYNC_VERSION=v0.9.2
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2

# Beszel Agent joins the Kuma Compose stack after Hub credentials are set.
# Keep real values only in /etc/edge-monitor.env (mode 600), never in Git.
INSTALL_BESZEL_AGENT=true
BESZEL_AGENT_IMAGE=henrygd/beszel-agent
BESZEL_LISTEN=45876
BESZEL_KEY=""
BESZEL_HUB_URL=""
BESZEL_TOKEN=""

# Ports exposed on LAN.
ADGUARD_UI_PORT=3000
UPTIME_KUMA_PORT=3001
