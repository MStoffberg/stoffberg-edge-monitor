# Tiny Edge is the sync controller; pve02 CT201 remains source of truth.
# Copy to /etc/adguardhome-sync/adguardhome-sync.yaml, add real credentials,
# chmod 600, then run one manual sync before enabling the service.
cron: "*/5 * * * *"
runOnStart: true
continueOnError: true
httpClientTimeout: 30s

origin:
  url: "http://10.0.0.201"
  username: "CHANGE_ME_PVE02_USERNAME"
  password: "CHANGE_ME_PVE02_PASSWORD"

replicas:
  # Main client-facing DNS on this Tiny Edge host.
  - url: "http://127.0.0.1:3000"
    username: "CHANGE_ME_TINY_EDGE_USERNAME"
    password: "CHANGE_ME_TINY_EDGE_PASSWORD"
  # pve CT101 secondary DNS.
  - url: "http://10.0.0.102:3000"
    username: "CHANGE_ME_CT101_USERNAME"
    password: "CHANGE_ME_CT101_PASSWORD"
  # TrueNAS-hosted/remote AdGuard management endpoint.
  - url: "http://192.168.101.140:30004"
    username: "CHANGE_ME_TRUENAS_USERNAME"
    password: "CHANGE_ME_TRUENAS_PASSWORD"

api:
  port: 0
features:
  dns:
    accessLists: true
    serverConfig: true
    rewrites: true
  dhcp:
    serverConfig: false
    staticLeases: false
  generalSettings: true
  protectionStatus: true
  queryLogConfig: true
  statsConfig: true
  clientSettings: true
  services: true
  filters:
    blacklist: true
    whitelist: true
    userRules: true
  theme: true
  tlsConfig: false
